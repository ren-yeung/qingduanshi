<view class="page food-lib-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}}; font-family: {{theme.fontFamily}}; --font-size-scale: {{theme.fontSizeScale}};">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-back" bindtap="onBack">
      <text class="back-icon" style="color: {{theme.textPrimary}};">‹</text>
    </view>
    <view class="navbar-title" style="color: {{theme.textPrimary}};">食物库</view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索食物名称" value="{{keyword}}" bindinput="onSearch" />
    </view>
  </view>

  <!-- 食物列表 -->
  <scroll-view class="food-list" scroll-y>
    <view
      class="food-item {{selectedFood && selectedFood.name === item.name ? 'food-item--active' : ''}}"
      wx:for="{{foods}}"
      wx:key="name"
      data-index="{{index}}"
      bindtap="onSelectFood"
    >
      <view class="food-info">
        <text class="food-name">{{item.name}}</text>
        <text class="food-category">{{item.category}}</text>
      </view>
      <text class="food-cal">{{item.caloriesPer100g}} kcal/100g</text>
    </view>
  </scroll-view>

  <!-- 底部白色底色 -->
  <view class="bottom-spacer" wx:if="{{selectedFood}}"></view>

  <!-- 底部详情面板 -->
  <view class="detail-panel" wx:if="{{selectedFood}}">
    <view class="detail-header">
      <text class="detail-name">{{selectedFood.name}}</text>
      <text class="detail-close" bindtap="onCloseDetail">✕</text>
    </view>
    <view class="detail-meta">
      <text>蛋白质 {{selectedFood.protein}}g · 碳水 {{selectedFood.carbs}}g · 脂肪 {{selectedFood.fat}}g（每100g）</text>
    </view>
    <view class="detail-calories">
      <text class="cal-label">热量</text>
      <text class="cal-value">{{selectedFood.caloriesPer100g}} kcal/100g</text>
    </view>
  </view>
</view>
