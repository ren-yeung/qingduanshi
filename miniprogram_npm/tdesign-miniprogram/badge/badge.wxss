.t-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
}
.t-badge__dot {
  width: 16rpx;
  height: 16rpx;
  background: #e34d59;
  border-radius: 50%;
}
.t-badge__dot--circle {
  border-radius: 50%;
}
.t-badge__dot--leaf {
  border-radius: 50% 0 50% 50%;
}
.t-badge__count {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  line-height: 32rpx;
  color: #fff;
  background: #e34d59;
  border-radius: 16rpx;
  text-align: center;
}
.t-badge__count--circle {
  border-radius: 16rpx;
}
.t-badge__count--leaf {
  border-radius: 16rpx 16rpx 16rpx 0;
}
