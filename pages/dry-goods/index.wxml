<view class="page dry-goods-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}};">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-title" style="color: {{theme.textPrimary}};">干货</view>
  </view>

  <view class="article-list" style="padding-top: {{listPaddingTop}}px;">
    <view class="article-card" wx:for="{{articles}}" wx:key="id" data-id="{{item.id}}" bindtap="onTapArticle">
      <view class="article-header">
        <text class="article-tag">{{item.tag}}</text>
      </view>
      <text class="article-title">{{item.title}}</text>
      <text class="article-summary">{{item.summary}}</text>
    </view>
  </view>
</view>
