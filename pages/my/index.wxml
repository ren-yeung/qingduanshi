<view class="page my-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}}; font-family: {{theme.fontFamily}}; --font-size-scale: {{theme.fontSizeScale}};">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-title" style="color: {{theme.textPrimary}};">{{t0 || '我的'}}</view>
  </view>

  <!-- 用户信息 -->
  <view class="user-card" style="background: {{theme.cardBg}};">
    <view class="user-info">
      <!-- 已登录：显示用户头像 -->
      <t-avatar wx:if="{{isLogin}}" image="{{userInfo.avatarUrl || defaultAvatar}}" size="large" bindtap="onChooseAvatar" />
      <!-- 未登录：显示默认猫咪头像 -->
      <image wx:else class="login-avatar" src="{{defaultAvatar}}" mode="aspectFill" bindtap="onLogin" />
      <view class="user-meta">
        <!-- 昵称输入模式 -->
        <view wx:if="{{isLogin && isEditingNickname}}" class="nickname-edit-wrapper">
          <input type="nickname" class="nickname-input" value="{{tempNickname}}" placeholder="{{t1 || '请输入昵称'}}" bindinput="onNicknameInput" bindconfirm="onConfirmNickname" focus="{{true}}" />
          <text class="confirm-btn" style="background: {{theme.brandPrimary}};" bindtap="onConfirmNickname">{{t2 || '完成'}}</text>
        </view>
        <!-- 昵称显示模式 -->
        <view wx:else class="nickname-display" bindtap="onEditNickname">
          <text class="user-name" style="color: {{theme.textPrimary}};">{{userInfo.nickName || (t3 || '小小的新用户')}}</text>
          <text class="edit-icon" wx:if="{{isLogin}}">✎</text>
        </view>
        <text class="user-streak">{{isLogin ? ('ID: ' + (userInfo.userId || '--')) : (t4 || '点击头像登录')}}</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="grid-card" style="background: {{theme.cardBg}};">
    <view class="grid-item" wx:for="{{gridList}}" wx:key="type" data-url="{{item.url}}" data-type="{{item.type}}" bindtap="onNavigate">
      <view class="grid-icon" style="background: {{theme.brandLight}};">
        <text class="icon-text">{{item.icon === 'target' ? '🎯' : item.icon === 'chart' ? '📊' : item.icon === 'app' ? '🍎' : '⏱️'}}</text>
      </view>
      <text class="grid-name" style="color: {{theme.textPrimary}};">{{item.name}}</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-card" style="background: {{theme.cardBg}};">
    <view class="palette-list">
      <view
        wx:for="{{menuList}}"
        wx:key="type"
        class="palette-cell {{index < menuList.length - 1 ? 'palette-cell--bordered' : ''}}"
        hover-class="palette-cell--hover"
        data-url="{{item.url}}"
        data-type="{{item.type}}"
        bindtap="onNavigate"
      >
        <text class="menu-icon">{{item.icon}}</text>
        <text class="palette-label">{{item.name}}</text>
        <text class="cell-arrow">›</text>
      </view>
    </view>
  </view>

</view>
