<view class="container body-dimension-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}}; font-family: {{theme.fontFamily}}; --font-size-scale: {{theme.fontSizeScale}};">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-back" bindtap="onBack">
      <text class="back-icon" style="color: {{theme.textPrimary}};">‹</text>
    </view>
    <view class="navbar-title" style="color: {{theme.textPrimary}};">{{t0 || '身体维度'}}</view>
  </view>

  <view class="page-content">

  <!-- ========== 1. 数据总览卡片 ========== -->
  <view class="overview-card">
    <view class="overview-inner">
      <view class="overview-header">
        <view class="overview-left">
          <text class="overview-label">{{t1 || '最新体重'}}</text>
          <view class="weight-row">
            <text class="weight-big">{{overview.weight}}</text>
            <text class="weight-unit">{{weightUnit || 'kg'}}</text>
          </view>
          <view class="weight-change {{overview.changeType}}">
            <text wx:if="{{overview.changeType === 'down'}}">↓ {{overview.change}} {{weightUnit || 'kg'}} {{t2 || '较上周'}}</text>
            <text wx:else>↑ {{overview.change}} {{weightUnit || 'kg'}} {{t2 || '较上周'}}</text>
          </view>
        </view>

        <view class="overview-metrics">
          <view class="metric-item">
            <text class="metric-val green">{{overview.bmi}}</text>
            <text class="metric-label">{{t3 || 'BMI'}}</text>
          </view>
          <view class="metric-item">
            <text class="metric-val blue">{{overview.bodyFat}}%</text>
            <text class="metric-label">{{t4 || '体脂率'}}</text>
          </view>
          <view class="metric-item">
            <text class="metric-val orange">{{overview.waist}}<text class="metric-unit">cm</text></text>
            <text class="metric-label">{{t5 || '腰围'}}</text>
          </view>
          <view class="metric-item">
            <text class="metric-val">{{overview.hip}}<text class="metric-unit">cm</text></text>
            <text class="metric-label">{{t6 || '臀围'}}</text>
          </view>
        </view>
      </view>

      <!-- BMI指示条 -->
      <view class="bmi-bar-wrap">
        <view class="bmi-bar-header">
          <text class="bmi-label">{{t7 || 'BMI 指数'}}</text>
          <text class="bmi-category {{bmiCategoryClass}}">{{bmiCategory}} {{bmiCategoryIcon}}</text>
        </view>
        <view class="bmi-track">
          <view class="bmi-indicator" style="left: {{bmiPosition}}%;"></view>
        </view>
        <view class="bmi-range-labels">
          <text>{{t24 || '偏瘦'}}</text><text>{{t28 || '正常'}}</text><text>{{t26 || '偏胖'}}</text><text>{{t27 || '肥胖'}}</text>
        </view>
      </view>
    </view>
  </view>


  <!-- ========== 2. 快捷录入按钮 ========== -->
  <view class="record-btn-bar">
    <button class="record-btn primary" bindtap="onRecordToday">
      <text decode="{{true}}">➕ </text>{{t8 || '记录今天的数据'}}
    </button>
    <button class="record-btn outline" bindtap="onViewHistory">
      <text decode="{{true}}">📋 </text>{{t9 || '历史记录'}}
    </button>
  </view>


  <!-- ========== 3. 目标进度 ========== -->
  <view class="section-card goal-card">
    <view class="section-header">
      <view class="section-title">
        <text class="emoji">🎯</text> {{t10 || '目标进度'}}
      </view>
      <view class="section-action" style="color:#E65100;" bindtap="onEditGoal">{{t11 || '修改'}} ›</view>
    </view>
    <view class="goal-progress-wrap">
      <view class="goal-info-row">
        <text class="goal-text">{{t29 || '目标：'}}{{goal.current}} {{weightUnit || 'kg'}} → {{goal.target}} {{weightUnit || 'kg'}}</text>
        <text class="goal-numbers">{{t12 || '已减'}} {{goal.lost}} / {{goal.total}} {{weightUnit || 'kg'}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{goal.progress}}%;"></view>
      </view>
      <text class="goal-hint">🎉 {{t30 || '再减 '}}{{goal.remain}} {{weightUnit || 'kg'}}{{t31 || ' 即可达成目标！预计还需 ~'}}{{goal.weeks}}{{t32 || ' 周'}}</text>
    </view>
  </view>


  <!-- ========== 4. 趋势图表 ========== -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-title">
        <text class="emoji">📈</text> {{t14 || '趋势变化'}}
      </view>
      <view class="section-action" bindtap="onViewMore">{{t15 || '近30天'}} ›</view>
    </view>

    <!-- 指标切换Tab -->
    <view class="chart-tabs">
      <button 
        wx:for="{{chartTypes}}" 
        wx:key="type"
        class="chart-tab {{currentChartType === item.type ? 'active' : ''}}"
        data-type="{{item.type}}"
        bindtap="onSwitchChart">{{item.name}}</button>
    </view>

    <!-- 图表区域 -->
    <view class="chart-area">
      <canvas canvas-id="trendChart" id="trendChart" class="chart-canvas" bindtouchstart="onTouchChart"></canvas>
    </view>

    <!-- X轴标签 -->
    <view class="x-axis-labels">
      <text wx:for="{{chartXLabels}}" wx:key="index" class="x-label">{{item}}</text>
    </view>

    <!-- 图表摘要 -->
    <view class="chart-summary">
      <view class="chart-stat">
        <text class="chart-stat-val">{{chartSummary.range}}</text>
        <text class="chart-stat-lbl">{{t16 || '区间'}}</text>
      </view>
      <view class="chart-stat">
        <text class="chart-stat-val down">{{chartSummary.change}}</text>
        <text class="chart-stat-lbl">{{t17 || '累计变化'}}</text>
      </view>
      <view class="chart-stat">
        <text class="chart-stat-val">{{chartSummary.count}} 次</text>
        <text class="chart-stat-lbl">{{t18 || '记录次数'}}</text>
      </view>
    </view>
  </view>


  <!-- ========== 5. 历史记录列表 ========== -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-title">
        <text class="emoji">📋</text> {{t19 || '记录历史'}}
      </view>
      <view class="section-action" bindtap="onViewAll">{{t20 || '全部'}} ›</view>
    </view>

    <view class="history-list" wx:if="{{historyList.length > 0}}">
      <view class="history-date-group" wx:for="{{historyList}}" wx:key="date">
        <view class="record-item" bindtap="onViewRecord" data-id="{{item._id}}">
          <view class="record-date-col">
            <text class="record-day">{{item.day}}</text>
            <text class="record-dow">{{item.dow}}</text>
          </view>
          <view class="record-data-col">
            <view class="record-main">
              <text>{{item.weight}} kg</text>
              <text class="record-main-sub"> BMI {{item.bmi}}</text>
            </view>
            <view class="record-sub">
              <text>体脂 {{item.bodyFat}}%</text>
              <text>腰围 {{item.waist || '—'}}cm</text>
              <text>{{item.mood}}</text>
            </view>
          </view>
          <text class="record-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:else>
      <text class="empty-icon">📊</text>
      <text class="empty-text">{{t21 || '暂无记录，开始记录你的身体数据吧'}}</text>
      <button class="empty-btn" bindtap="onRecordToday">{{t22 || '立即记录'}}</button>
    </view>
  </view>


  <view class="bottom-tip">— 向上滑动回到顶部 —</view>

  </view>
</view>
