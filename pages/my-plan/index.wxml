<view class="page my-plan-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}}; font-family: {{theme.fontFamily}}; --font-size-scale: {{theme.fontSizeScale}};">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-back" bindtap="onBack">
      <text class="back-icon" style="color: {{theme.textPrimary}};">‹</text>
    </view>
    <view class="navbar-title" style="color: {{theme.textPrimary}};">{{t0 || '我的计划'}}</view>
  </view>

  <view class="page-content">

    <!-- ========== 1. 当前计划主卡片 ========== -->
    <view class="plan-hero-card">
      <view class="plan-hero-inner">

        <!-- 头部信息 -->
        <view class="hero-top">
          <view class="hero-left">
            <view class="status-tag {{planStatus !== 'idle' ? 'active' : 'paused'}}">
              <view class="status-dot" wx:if="{{planStatus !== 'idle'}}"></view>
              <block wx:if="{{planStatus !== 'idle'}}">{{t1 || '进行中'}}</block>
              <block wx:else>{{t2 || '已结束'}}</block>
            </view>
            <view class="plan-name">{{currentPlan.name}}</view>
            <view class="plan-desc">{{t3 || '每日断食'}}{{currentPlan.fastHours}}{{t4 || '小时'}} · {{t5 || '进食窗口'}}{{currentPlan.eatHours}}{{t4 || '小时'}}</view>
          </view>
        </view>

        <!-- 环形进度 + 统计 -->
        <view class="ring-section">
          <view class="ring-container">
            <canvas canvas-id="progressRing" class="ring-canvas"></canvas>
            <view class="ring-center">
              <view class="ring-percent">{{todayProgress}}%</view>
              <view class="ring-label">{{t6 || '今日'}}</view>
            </view>
          </view>

          <view class="ring-stats">
            <view class="stat-item">
              <view class="stat-value green">{{streak}}</view>
              <view class="stat-label">{{t7 || '连续天数'}}</view>
            </view>
            <view class="stat-item">
              <view class="stat-value orange">{{maxStreak}}</view>
              <view class="stat-label">{{t8 || '最长连续'}}</view>
            </view>
            <view class="stat-item">
              <view class="stat-value">{{monthCompletionRate}}%</view>
              <view class="stat-label">{{t9 || '本月完成率'}}</view>
            </view>
            <view class="stat-item">
              <view class="stat-value">{{totalFastingHours}}<text class="stat-unit">h</text></view>
              <view class="stat-label">{{t10 || '累计断食'}}</view>
            </view>
          </view>
        </view>

      </view>

      <!-- 操作按钮 -->
      <view class="hero-actions">
        <view class="action-btn primary" bindtap="onSwitchPlan">
          ⚡ {{t11 || '切换方案'}}
        </view>
        <view class="action-btn outline" bindtap="onEndPlan" wx:if="{{planStatus !== 'idle'}}">
          ⏹ {{t12 || '结束计划'}}
        </view>
      </view>
    </view>


    <!-- ========== 2. 本周日历概览 ========== -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-title">📅 {{t13 || '本周概览'}}</view>
        <view class="section-action" bindtap="onViewAll">{{t14 || '查看全部'}} ›</view>
      </view>

      <view class="calendar-week">
        <view class="weekday-row">
          <view class="weekday-label">{{t15 || '日'}}</view>
          <view class="weekday-label">{{t16 || '一'}}</view>
          <view class="weekday-label">{{t17 || '二'}}</view>
          <view class="weekday-label">{{t18 || '三'}}</view>
          <view class="weekday-label">{{t19 || '四'}}</view>
          <view class="weekday-label">{{t20 || '五'}}</view>
          <view class="weekday-label">{{t21 || '六'}}</view>
        </view>
        <view class="day-grid">
          <view
            class="day-cell {{item.status}} {{item.isToday ? 'today' : ''}}"
            wx:for="{{weekDays}}"
            wx:key="date"
            data-date="{{item.date}}"
            bindtap="onDayTap"
          >
            <view class="day-num">{{item.day}}</view>
            <view class="day-status-dot {{item.dotClass}}"></view>
          </view>
        </view>
      </view>

      <!-- 周摘要 -->
      <view class="week-summary">
        <view class="summary-item">
          <view class="summary-val">{{weekStats.completed}}<text class="summary-sub">/7</text></view>
          <view class="summary-lbl">{{t22 || '已完成'}}</view>
        </view>
        <view class="summary-item">
          <view class="summary-val">{{weekStats.progress}}%</view>
          <view class="summary-lbl">{{t23 || '周进度'}}</view>
        </view>
        <view class="summary-item">
          <view class="summary-val">{{weekStats.fastingHours}}h</view>
          <view class="summary-lbl">{{t24 || '本周断食'}}</view>
        </view>
        <view class="summary-item">
          <view class="summary-val">🔥 {{streak}}</view>
          <view class="summary-lbl">{{t25 || '连续中'}}</view>
        </view>
      </view>
    </view>


    <!-- ========== 3. 数据统计面板 ========== -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-title">📊 {{t26 || '成就数据'}}</view>
        <view class="section-action" bindtap="onViewReport">{{t27 || '详细报告'}} ›</view>
      </view>

      <view class="stats-grid">
        <view class="stat-box green">
          <view class="stat-icon">⏱️</view>
          <view class="stat-number">{{totalFastingHours}}<text class="stat-unit">{{t4 || '小时'}}</text></view>
          <view class="stat-hint">{{t28 || '累计断食总时长'}}</view>
          <view class="stat-trend trend-up">↑ {{t42 || '较上周'}} +{{weekGrowth}}h</view>
        </view>
        <view class="stat-box blue">
          <view class="stat-icon">🔥</view>
          <view class="stat-number">{{maxStreak}}<text class="stat-unit">{{t29 || '天'}}</text></view>
          <view class="stat-hint">{{t30 || '历史最长连续'}}</view>
          <view class="stat-trend trend-up">{{t31 || '保持记录中'}} 🏆</view>
        </view>
        <view class="stat-box orange">
          <view class="stat-icon">📅</view>
          <view class="stat-number">{{monthDaysCompleted}}<text class="stat-unit">/{{monthDaysTotal}}</text></view>
          <view class="stat-hint">{{t32 || '本月完成天数'}}</view>
          <view class="stat-trend trend-up">{{t38 || '完成率'}} {{monthCompletionRate}}%</view>
        </view>
        <view class="stat-box purple">
          <view class="stat-icon">💪</view>
          <view class="stat-number"><text class="week-prefix">{{t34 || '第'}}</text><text class="stat-unit week-num">{{currentWeek}}</text><text class="week-suffix">{{t35 || '周'}}</text></view>
          <view class="stat-hint">{{t33 || '持续坚持周期'}}</view>
          <view class="stat-trend trend-up">{{weeksToBadge}}{{t43 || '周后解锁徽章'}}</view>
        </view>
      </view>
    </view>



    
    <!-- ========== 5. 历史计划归档 ========== -->
    <view class="section-card history-section">
      <view class="section-header">
        <view class="section-title">📜 {{t36 || '历史计划'}}</view>
        <view class="section-action" bindtap="onViewHistory">{{t37 || '更多'}} ›</view>
      </view>

      <view class="history-list">
        <view
          class="history-item"
          wx:for="{{historyPlans}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onHistoryItemTap"
        >
          <view class="history-icon-wrap {{item.iconClass}}">{{item.icon}}</view>
          <view class="history-info">
            <view class="history-plan-name">{{item.name}}</view>
            <view class="history-period">{{item.startDate}} — {{item.endDate}} · {{item.tag}}</view>
          </view>
          <view class="history-result">
            <view class="history-days">{{item.days}}<text class="history-days-unit">{{t29 || '天'}}</text></view>
            <view class="history-days-label">{{t38 || '完成率'}} {{item.completionRate}}%</view>
          </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{historyPlans.length === 0}}">
          <view class="empty-icon">📋</view>
          <view class="empty-text">{{t39 || '暂无历史计划'}}</view>
          <view class="empty-btn" bindtap="onCreatePlan">{{t40 || '创建新计划'}}</view>
        </view>
      </view>
    </view>


    <!-- 底部间距 -->
    <view class="bottom-tip">— {{t41 || '向上滑动回到顶部'}} —</view>

  </view>

</view>
