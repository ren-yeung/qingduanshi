<!-- 自定义导航栏 -->
<view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}}; font-family: {{theme.fontFamily}};">
  <view class="navbar-back" bindtap="onBack">
    <text class="back-icon" style="color: {{theme.textPrimary}};">‹</text>
  </view>
  <view class="navbar-title" style="color: {{theme.textPrimary}};">{{t0 || '完善个人信息'}}</view>
</view>

<view class="page info-collection" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}}; font-family: {{theme.fontFamily}}; --font-size-scale: {{theme.fontSizeScale}};">
  <!-- 标题区 -->
  <view class="header">
    <view class="header-subtitle">{{t1 || '帮助我们为你提供更精准的断食方案'}}</view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- 性别 -->
    <view class="form-section">
      <view class="section-label">{{t2 || '选择您的性别'}}</view>
      <view class="gender-row">
        <view class="gender-option {{gender === 'female' ? 'active' : ''}}" bindtap="setGender" data-gender="female">
          <view class="gender-icon-wrap female-icon">
            <text class="gender-emoji">♀</text>
          </view>
          <view class="gender-label-row">
            <text class="gender-text">{{t3 || '女生'}}</text>
            <view class="check-circle {{gender === 'female' ? 'checked' : ''}}"></view>
          </view>
        </view>
        <view class="gender-option {{gender === 'male' ? 'active' : ''}}" bindtap="setGender" data-gender="male">
          <view class="gender-icon-wrap male-icon">
            <text class="gender-emoji">♂</text>
          </view>
          <view class="gender-label-row">
            <text class="gender-text">{{t4 || '男生'}}</text>
            <view class="check-circle {{gender === 'male' ? 'checked' : ''}}"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 出生年月 -->
    <view class="form-section">
      <view class="section-label">{{t5 || '选择您的出生年月'}}</view>
      <picker mode="multiSelector" bindchange="onBirthdayChange" value="{{birthdayIndex}}" range="{{birthdayRange}}">
        <view class="birthday-display">
          <text class="birthday-text">{{birthdayDisplay}}</text>
          <text class="birthday-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 身高 -->
    <view class="form-section">
      <view class="section-label">{{t6 || '选择您的身高'}}</view>
      <view class="ruler-display">
        <text class="ruler-value">{{height}}</text>
        <text class="ruler-unit">cm</text>
      </view>
      <view class="ruler-wrapper">
        <!-- 刻度尺容器（可滚动） -->
        <view class="ruler-scroll-area" bindtouchstart="onHeightTouchStart" bindtouchmove="onHeightTouchMove" bindtouchend="onHeightTouchEnd">
          <!-- 刻度尺（会平移） -->
          <view class="ruler-scale ruler-scale-height" style="transform: translateX({{heightOffset}}px)">
            <view wx:for="{{heightTicks}}" wx:key="index" class="tick-item {{item.major ? 'tick-major' : ''}}" style="width: {{heightTickWidth}}px">
              <view class="tick-line"></view>
              <text wx:if="{{item.major}}" class="tick-text">{{item.value}}</text>
            </view>
          </view>
        </view>
        <!-- 固定指示箭头 -->
        <view class="fixed-indicator"></view>
      </view>
      <view class="ruler-range">
        <text>85cm</text>
        <text>250cm</text>
      </view>
    </view>

    <!-- 体重 -->
    <view class="form-section">
      <view class="section-label">{{t7 || '选择您当前体重'}}</view>
      <view class="ruler-display">
        <text class="ruler-value">{{weight % 1 === 0 ? weight + '.0' : weight}}</text>
        <text class="ruler-unit">kg</text>
      </view>
      <view class="ruler-wrapper">
        <!-- 刻度尺容器（可滚动） -->
        <view class="ruler-scroll-area" bindtouchstart="onWeightTouchStart" bindtouchmove="onWeightTouchMove" bindtouchend="onWeightTouchEnd">
          <!-- 刻度尺（会平移） -->
          <view class="ruler-scale ruler-scale-weight" style="transform: translateX({{weightOffset}}px)">
            <view wx:for="{{weightTicks}}" wx:key="index" class="tick-item {{item.major ? 'tick-major' : ''}}" style="width: {{weightTickWidth}}px">
              <view class="tick-line"></view>
              <text wx:if="{{item.major}}" class="tick-text">{{item.value}}</text>
            </view>
          </view>
        </view>
        <!-- 固定指示箭头 -->
        <view class="fixed-indicator"></view>
      </view>
      <view class="ruler-range">
        <text>30kg</text>
        <text>150kg</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮（放在 .page 内部以继承 --brand-primary CSS 变量） -->
  <view class="bottom-btn">
    <button class="submit-btn" bindtap="submitForm">{{t8 || '开始体验'}}</button>
  </view>
</view>
