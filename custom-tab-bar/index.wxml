<view class="custom-tab-bar">
  <view
    wx:for="{{tabs}}"
    wx:key="value"
    class="tab-item {{value === item.value ? 'tab-item--active' : ''}}"
    data-value="{{item.value}}"
    bindtap="onTabTap"
  >
    <image
      class="tab-icon"
      src="{{item.selectedIcon}}"
      mode="aspectFit"
      style="filter: {{value === item.value ? iconFilter : 'grayscale(100%)'}}; opacity: {{value === item.value ? 1 : 1}};"
    />
    <text class="tab-label" style="color: {{value === item.value ? activeColor : '#999'}};">{{item.label}}</text>
  </view>
</view>