.t-avatar__wrapper {
  display: inline-flex;
  position: relative;
}

.t-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #d9e1ff;
  color: #0052d9;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.t-avatar--small {
  width: 80rpx;
  height: 80rpx;
  font-size: 40rpx;
}

.t-avatar--medium {
  width: 96rpx;
  height: 96rpx;
  font-size: 48rpx;
}

.t-avatar--large {
  width: 128rpx;
  height: 128rpx;
  font-size: 64rpx;
}

.t-avatar--circle {
  border-radius: 50%;
  overflow: hidden;
}

.t-avatar--round {
  border-radius: 12rpx;
  overflow: hidden;
}

.t-avatar__image {
  width: 100%;
  height: 100%;
}

.t-avatar__icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
