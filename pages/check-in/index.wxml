<view class="page checkin-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}};">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-back" bindtap="onBack">
      <text class="back-icon" style="color: {{theme.textPrimary}};">‹</text>
    </view>
    <view class="navbar-title" style="color: {{theme.textPrimary}};">打卡分享</view>
  </view>

  <view class="checkin-card">
    <view class="checkin-badge">
      <text class="badge-icon">🔥</text>
    </view>
    <text class="checkin-title">打卡成功</text>
    <view class="streak-number">
      <text class="number">{{streak}}</text>
      <text class="unit">天</text>
    </view>
    <text class="streak-label">连续打卡</text>
    <view class="quote-box">
      <text class="quote-text">{{quote}}</text>
    </view>
  </view>

  <view class="action-btns">
    <button open-type="share" class="share-btn">分享给好友</button>
    <view class="back-btn" bindtap="onBack">返回首页</view>
  </view>
</view>
