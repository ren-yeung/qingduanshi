.t-image {
  position: relative;
  display: inline-block;
  overflow: hidden;
}
.t-image--round {
  border-radius: 50%;
}
.t-image--rounded {
  border-radius: 16rpx;
}
.t-image__img {
  width: 100%;
  height: 100%;
}
.t-image__img--loaded {
  opacity: 1;
}
.t-image__loading {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}
