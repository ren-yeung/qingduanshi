<view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}}; font-family: {{theme.fontFamily}};">
  <view class="navbar-back" bindtap="onBack">
    <text class="back-icon">‹</text>
  </view>
  <view class="navbar-title" style="color: {{theme.textPrimary}};">{{t0 || '深色模式'}}</view>
</view>

<view class="page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}}; font-family: {{theme.fontFamily}}; --font-size-scale: {{theme.fontSizeScale}};">

  <!-- 外观主题 -->
  <view class="section-label">{{t1 || '外观主题'}}</view>
  <view class="radio-card">
    <!-- 跟随系统 -->
    <view class="radio-option" data-value="follow" bindtap="onRadioChange">
      <view class="radio-left">
        <text class="radio-text">{{t2 || '跟随系统'}}</text>
        <text class="radio-desc">{{t3 || '自动根据手机系统的深色/浅色模式切换外观'}}</text>
      </view>
      <view class="radio-circle {{darkMode === 'follow' ? 'checked' : ''}}"></view>
    </view>

    <!-- 浅色模式 -->
    <view class="radio-option" data-value="light" bindtap="onRadioChange">
      <view class="radio-left">
        <text class="radio-text">☀️ {{t4 || '浅色模式'}}</text>
        <text class="radio-desc">{{t5 || '始终使用浅色模式，适合大多数场景'}}</text>
      </view>
      <view class="radio-circle {{darkMode === 'light' ? 'checked' : ''}}"></view>
    </view>

    <!-- 深色模式 -->
    <view class="radio-option radio-option-last" data-value="dark" bindtap="onRadioChange">
      <view class="radio-left">
        <text class="radio-text">🌙 {{t6 || '深色模式'}}</text>
        <text class="radio-desc">{{t7 || '适合夜间或低光环境使用，更护眼并省电'}}</text>
      </view>
      <view class="radio-circle {{darkMode === 'dark' ? 'checked' : ''}}"></view>
    </view>
  </view>

  <!-- 提示框 -->
  <view class="tip-box">
    <text class="tip-icon">🌙</text>
    <text class="tip-text">{{t8 || '选择「跟随系统」时，小程序将根据手机系统的深色/浅色模式自动切换外观。'}}</text>
  </view>

  <!-- 效果预览 -->
  <view class="section-label">{{t9 || '效果预览'}}</view>
  <view class="preview-row">
    <!-- 浅色预览 -->
    <view class="preview-card preview-light">
      <text class="preview-label">{{t10 || '浅色'}}</text>
      <view class="preview-inner">
        <text class="preview-text-light">{{t11 || '预览区域'}}</text>
      </view>
    </view>

    <!-- 深色预览 -->
    <view class="preview-card preview-dark">
      <text class="preview-label">{{t12 || '深色'}}</text>
      <view class="preview-inner">
        <text class="preview-text-dark">{{t11 || '预览区域'}}</text>
      </view>
    </view>
  </view>
</view>
