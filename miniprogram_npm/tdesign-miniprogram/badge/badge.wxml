<view class="t-badge" style="{{color ? 'background-color:' + color : ''}}" wx:if="{{visible}}">
  <block wx:if="{{dot}}">
    <view class="t-badge__dot t-badge__dot--{{shape}}"></view>
  </block>
  <block wx:else>
    <view class="t-badge__count t-badge__count--{{shape}}">{{displayCount}}</view>
  </block>
</view>
