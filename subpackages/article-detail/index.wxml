<view class="detail-page" style="--brand-primary:{{theme.brandPrimary}};--brand-light:{{theme.brandLight}};--brand-dark:{{theme.brandDark}};--brand-primary-rgb:{{theme.brandPrimaryRgb}};--brand-dark-rgb:{{theme.brandDarkRgb}}; background: {{theme.bgColor}};">
  <!-- 自定义导航栏 -->
  <view class="navbar" style="padding-top: {{statusBarHeight}}px; background: {{theme.navBg}};">
    <view class="navbar-back" bindtap="onBack">
      <text class="back-icon" style="color: {{theme.textPrimary}};">‹</text>
    </view>
    <view class="navbar-title" style="color: {{theme.textPrimary}};">文章详情</view>
  </view>

  <block wx:if="{{article}}">
    <!-- 文章头部 -->
    <view class="article-header" style="margin-top: {{headerMarginTop}}px;">
      <text class="article-tag">{{article.tag}}</text>
      <text class="article-title">{{article.coverTitle}}</text>
      <view class="article-meta">
        <text class="meta-icon">⏳</text>
        <text>{{article.readTime}}</text>
      </view>
    </view>
    <view class="header-divider"></view>

    <!-- 封面图 -->
    <image
      wx:if="{{article.images.cover}}"
      class="cover-image"
      src="{{article.images.cover}}"
      mode="widthFix"
      lazy-load
    />

    <!-- 正文内容 -->
    <view class="article-body">

      <block wx:for="{{article.sections}}" wx:key="index">

        <!-- 章节标题 -->
        <view class="section-heading" wx:if="{{item.heading}}">{{item.heading}}</view>

        <!-- 普通段落 -->
        <block wx:for="{{item.body}}" wx:for-item="p" wx:key="*this" wx:if="{{p}}">
          <view class="section-para">{{p}}</view>
        </block>

        <!-- 独立引用文字 -->
        <view class="quote-text" wx:if="{{item.quote}}">{{item.quote}}</view>

        <!-- 高亮引用块 -->
        <view class="highlight-box" wx:if="{{item.highlight}}">
          <text class="highlight-text">{{item.highlight}}</text>
        </view>

        <!-- 要点列表 -->
        <view class="bullet-list" wx:if="{{item.bullets && item.bullets.length > 0}}">
          <view class="bullet-item" wx:for="{{item.bullets}}" wx:key="*this">
            <view class="bullet-dot"></view>
            <rich-text class="bullet-text" nodes="{{item}}"></rich-text>
          </view>
        </view>

        <!-- 内嵌图片 -->
        <view class="inline-image-wrap" wx:if="{{item.image}}">
          <!-- type 类型图片（从 article.images 中按 type 取对应路径） -->
          <block wx:if="{{item.image.type}}">
            <image
              class="inline-image"
              src="{{article.images[item.image.type]}}"
              mode="widthFix"
              lazy-load
            />
          </block>
          <!-- src 类型（兼容老写法：按 src 字段映射） -->
          <block wx:elif="{{item.image.src}}">
            <image
              class="inline-image"
              src="{{article.images[item.image.src]}}"
              mode="widthFix"
              lazy-load
            />
          </block>
          <view class="image-caption" wx:if="{{item.image.caption}}">{{item.image.caption}}</view>
        </view>

        <!-- 对比表格 -->
        <view class="compare-table" wx:if="{{item.table}}">
          <view class="table-head">
            <text class="th" wx:for="{{item.table.headers}}" wx:key="*this" style="flex:1">{{item}}</text>
          </view>
          <view class="table-row" wx:for="{{item.table.rows}}" wx:key="index">
            <text class="td td-first" style="flex:1">{{item[0]}}</text>
            <text class="td" style="flex:1">{{item[1]}}</text>
            <text class="td td-last" style="flex:1">{{item[2]}}</text>
          </view>
        </view>

        <!-- 标签组（适合/不适合人群） -->
        <block wx:if="{{item.tags}}">
          <view class="tag-section" wx:if="{{item.tags.yes && item.tags.yes.length > 0}}">
            <view class="tag-list tag-yes">
              <view class="tag-yes-item" wx:for="{{item.tags.yes}}" wx:key="*this">
                <text class="tag-check">✅</text>
                <text>{{item}}</text>
              </view>
            </view>
            <text class="tag-footer yes-hint">以上人群都可以放心尝试 🎉</text>
          </view>
          <view class="tag-section" wx:if="{{item.tags.no && item.tags.no.length > 0}}">
            <view class="tag-list tag-no">
              <view class="tag-no-item" wx:for="{{item.tags.no}}" wx:key="*this">
                <text class="tag-warn">⚠️</text>
                <text>{{item}}</text>
              </view>
            </view>
            <text class="tag-footer no-hint">以上人群请慎重，建议先咨询医生 🤔</text>
          </view>
        </block>

        <!-- 步骤卡片 -->
        <view class="step-card" wx:for="{{item.steps}}" wx:key="num" wx:if="{{item.steps}}">
          <view class="step-header">
            <view class="step-num">{{item.num}}</view>
            <text class="step-title">{{item.title}}</text>
          </view>
          <view class="step-items">
            <view class="step-item" wx:for="{{item.items}}" wx:key="*this">
              <text class="step-bullet">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 饮品列表 -->
        <view class="drink-list" wx:for="{{item.drinkList}}" wx:key="name" wx:if="{{item.drinkList}}">
          <view class="drink-card">
            <view class="drink-name-row">
              <text class="drink-emoji">{{item.emoji}}</text>
              <text class="drink-name">{{item.name}}</text>
            </view>
            <text class="drink-reason">{{item.reason}}</text>
            <view class="drink-tip" wx:if="{{item.tip}}">
              <text class="tip-label">💡 小贴士</text>
              <text class="tip-text">{{item.tip}}</text>
            </view>
          </view>
        </view>

        <!-- 方案卡片 -->
        <view class="scheme-card" wx:for="{{item.cards}}" wx:key="scheme" wx:if="{{item.cards}}">
          <view class="scheme-badge">{{item.badge}}</view>
          <view class="scheme-scheme">{{item.scheme}}</view>
          <view class="scheme-time">{{item.time}}</view>
          <text class="scheme-desc">{{item.desc}}</text>
          <view class="scheme-pros">
            <text class="scheme-label good">✅ 优势</text>
            <view class="scheme-tag-list">
              <text class="scheme-tag" wx:for="{{item.pros}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
          <view class="scheme-cons">
            <text class="scheme-label bad">❌ 注意</text>
            <view class="scheme-tag-list">
              <text class="scheme-tag dark" wx:for="{{item.cons}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- Q&A 列表 -->
        <view class="qa-block" wx:for="{{item.qa}}" wx:key="q" wx:if="{{item.qa}}">
          <view class="qa-q">
            <text class="qa-icon-q">Q</text>
            <text class="qa-question">{{item.q}}</text>
          </view>
          <view class="qa-a">
            <text class="qa-icon-a">A</text>
            <text class="qa-answer">{{item.a}}</text>
          </view>
        </view>

        <!-- 运动强度分区 -->
        <view class="zones-block" wx:if="{{item.intensityZones}}">
          <!-- 绿区 -->
          <view class="zone-card zone-green">
            <view class="zone-label">{{item.intensityZones.green.label}}</view>
            <text class="zone-desc">{{item.intensityZones.green.desc}}</text>
            <view class="zone-items">
              <text class="zone-item" wx:for="{{item.intensityZones.green.items}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="zone-why">
              <text class="why-label">为什么适合：</text>
              <text class="why-text">{{item.intensityZones.green.why}}</text>
            </view>
          </view>
          <!-- 黄区 -->
          <view class="zone-card zone-yellow">
            <view class="zone-label">{{item.intensityZones.yellow.label}}</view>
            <text class="zone-desc">{{item.intensityZones.yellow.desc}}</text>
            <view class="zone-items">
              <text class="zone-item" wx:for="{{item.intensityZones.yellow.items}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="zone-why">
              <text class="why-label">为什么需要谨慎：</text>
              <text class="why-text">{{item.intensityZones.yellow.why}}</text>
            </view>
          </view>
          <!-- 红区 -->
          <view class="zone-card zone-red">
            <view class="zone-label">{{item.intensityZones.red.label}}</view>
            <text class="zone-desc">{{item.intensityZones.red.desc}}</text>
            <view class="zone-items">
              <text class="zone-item" wx:for="{{item.intensityZones.red.items}}" wx:key="*this">{{item}}</text>
            </view>
            <view class="zone-why">
              <text class="why-label">为什么避免：</text>
              <text class="why-text">{{item.intensityZones.red.why}}</text>
            </view>
          </view>
        </view>

        <!-- 时间槽位卡片 -->
        <view class="time-slot" wx:for="{{item.timeSlots}}" wx:key="when" wx:if="{{item.timeSlots}}">
          <view class="slot-header">
            <text class="slot-when">{{item.when}}</text>
          </view>
          <view class="slot-body">
            <view class="slot-best" wx:if="{{item.bestFor.length > 0}}">
              <text class="slot-label">推荐运动</text>
              <view class="slot-tags">
                <text class="slot-tag" wx:for="{{item.bestFor}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="slot-detail">
              <view class="slot-pros">
                <text class="slot-mini-label good">优势</text>
                <text class="slot-mini-item" wx:for="{{item.pros}}" wx:key="*this">{{item}}</text>
              </view>
              <view class="slot-cons">
                <text class="slot-mini-label bad">注意</text>
                <text class="slot-mini-item" wx:for="{{item.cons}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="slot-tip" wx:if="{{item.tip}}">
              <text class="tip-symbol">💡</text>
              <text class="tip-content">{{item.tip}}</text>
            </view>
          </view>
        </view>

        <!-- 结束标识 -->
        <view class="end-mark" wx:if="{{item.ending}}">END</view>

        <!-- 下一篇引导 -->
        <view class="next-hint" wx:if="{{item.nextHint}}">
          <text class="next-text">{{item.nextHint}}</text>
        </view>

      </block>
    </view>
  </block>
</view>
